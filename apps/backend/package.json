{
  "name": "backend",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "prisma generate && tsc",
    "start": "prisma db push --accept-data-loss && node dist/app.js",
    "typecheck": "tsc --noEmit",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fastify/cookie": "^9.3.0",
    "@fastify/jwt": "^8.0.0",
    "@pc-remote/shared": "workspace:*",
    "@prisma/client": "^5.14.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "fastify": "^4.27.0",
    "fastify-plugin": "^4.5.1",
    "socket.io": "^4.7.5",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.14.0",
    "pino-pretty": "^11.0.0",
    "prisma": "^5.14.0",
    "socket.io-client": "^4.8.3",
    "tsx": "^4.15.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.0"
  }
}